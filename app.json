{
  "expo": {
    "name": "move-chilld",
    "slug": "move-chilld",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "movechilld",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "supabaseUrl": "https://fmvlithkfqinkiuobtak.supabase.co",
      "supabasePublishableKey": "sb_publishable_wJaEWbXKqAxDD8qubA0XZQ_P82n8J_b",
      "router": {},
      "eas": {
        "projectId": "41b7bf38-d0b0-42e2-9a6a-acf8ea7a7cc4"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.movechilld.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.movechilld.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFF9EE",
          "dark": {
            "backgroundColor": "#1A1A2E"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Move-Chilld utilise votre position pour partager la position du bus scolaire avec les parents."
        }
      ],
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "jerem148"
  }
}
